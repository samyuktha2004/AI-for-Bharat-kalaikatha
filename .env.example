# ════════════════════════════════════════════════════════
# KALAIKATHA — AWS Environment Variables
# Copy this file to .env.local and fill in your values
# Priority: Cognito > S3 > Bedrock > Translate > Rekognition > Polly
# ════════════════════════════════════════════════════════

# ── REQUIRED: AWS Region ──────────────────────────────────────────────────────
VITE_AWS_REGION=ap-south-1

# ── PRIORITY 1: AWS Cognito (Authentication) ──────────────────────────────────
# Get from: AWS Console → Cognito → User Pools
VITE_AWS_COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
VITE_AWS_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_AWS_COGNITO_IDENTITY_POOL_ID=ap-south-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── PRIORITY 2: AWS S3 (Image Storage) ────────────────────────────────────────
# Get from: AWS Console → S3 → Bucket name
VITE_AWS_S3_BUCKET=kalaikatha-artisan-uploads
VITE_AWS_S3_REGION=ap-south-1

# ── PRIORITY 3: AWS Bedrock (AI — Claude 3 Sonnet) ────────────────────────────
# NOTE: Bedrock is only in us-east-1 or us-west-2 (NOT ap-south-1 yet)
# Get from: AWS Console → Bedrock → Model access → Enable Claude 3 Sonnet
VITE_AWS_BEDROCK_REGION=us-east-1
VITE_AWS_BEDROCK_MODEL=anthropic.claude-3-sonnet-20240229-v1:0

# ── PRIORITY 4: AWS Translate (Hindi/Tamil/English) ───────────────────────────
# Auto-enabled in ap-south-1, no extra setup needed beyond Identity Pool access
VITE_AWS_TRANSLATE_REGION=ap-south-1

# ── PRIORITY 5: AWS Rekognition (Image Analysis) ──────────────────────────────
# Auto-enabled in ap-south-1, no extra setup needed beyond Identity Pool access
VITE_AWS_REKOGNITION_REGION=ap-south-1

# ── PRIORITY 6: AWS Polly (Text-to-Speech) ────────────────────────────────────
# Kajal voice requires Neural engine (us-east-1); Aditi works in ap-south-1
VITE_AWS_POLLY_REGION=ap-south-1
VITE_AWS_POLLY_VOICE_ENGLISH=Aditi
VITE_AWS_POLLY_VOICE_HINDI=Kajal
VITE_AWS_POLLY_VOICE_TAMIL=Aditi

# ── PRIORITY 7: AWS Transcribe (Voice Input) ──────────────────────────────────
# Browser Web Speech API is used as MVP fallback (works without setup)
VITE_AWS_TRANSCRIBE_REGION=ap-south-1

# ── OPTIONAL: OpenAI (secondary AI fallback if Bedrock not available) ─────────
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-3.5-turbo

# ── REMOVED: Azure & Firebase (migrated to AWS) ───────────────────────────────
# VITE_AZURE_VISION_ENDPOINT  → AWS Rekognition
# VITE_AZURE_SPEECH_KEY       → AWS Polly + Transcribe
# VITE_AZURE_OPENAI_KEY       → AWS Bedrock
# VITE_AZURE_TRANSLATOR_KEY   → AWS Translate
# VITE_FIREBASE_API_KEY       → AWS Cognito
# VITE_FIREBASE_PROJECT_ID    → AWS Cognito
