# Kalaikatha AWS Configuration Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git — it's already in .gitignore

# ========== REQUIRED REGION ==========
VITE_AWS_REGION=ap-south-1

# ========== COGNITO AUTH ==========
# Get these from AWS Cognito Console
VITE_AWS_COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXXXXXX
VITE_AWS_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_AWS_COGNITO_IDENTITY_POOL_ID=ap-south-1:XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# ========== S3 STORAGE ==========
# S3 bucket name for image/document uploads
VITE_AWS_S3_BUCKET=kalaikatha-artisan-uploads
VITE_AWS_S3_REGION=ap-south-1

# ========== BEDROCK AI ==========
# Bedrock is only available in us-east-1
VITE_AWS_BEDROCK_REGION=us-east-1
# Model options:
#   - anthropic.claude-3-haiku-20240307-v1:0 (cheaper, faster)
#   - anthropic.claude-3-sonnet-20240229-v1:0 (better quality)
VITE_AWS_BEDROCK_MODEL=anthropic.claude-3-haiku-20240307-v1:0

# ========== TRANSLATE SERVICE ==========
VITE_AWS_TRANSLATE_REGION=ap-south-1

# ========== REKOGNITION (Image Analysis) ==========
VITE_AWS_REKOGNITION_REGION=ap-south-1

# ========== POLLY (Text-to-Speech) ==========
VITE_AWS_POLLY_REGION=ap-south-1
# Voice options for each language
VITE_AWS_POLLY_VOICE_ENGLISH=Aditi
VITE_AWS_POLLY_VOICE_HINDI=Kajal
VITE_AWS_POLLY_VOICE_TAMIL=Aditi

# ========== TRANSCRIBE (Speech-to-Text) ==========
VITE_AWS_TRANSCRIBE_REGION=ap-south-1

# ========== CLOUDINARY (Image Enhancement) ==========
# Get from: https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# ========== TWILIO (WhatsApp Notifications - Optional) ==========
# Get from: https://www.twilio.com/console
VITE_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_TWILIO_AUTH_TOKEN=your_auth_token_here
VITE_TWILIO_WHATSAPP_NUMBER=+1234567890

# ========== AWS AMPLIFY API ENDPOINT (Optional) ==========
# Set after deploying Lambda function for WhatsApp
# Format: https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod/send-whatsapp
VITE_AWS_AMPLIFY_API_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod/send-whatsapp

# ========== OPENAI (Marketing Content - Optional) ==========
# Get from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
